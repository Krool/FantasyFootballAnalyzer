{
  "name": "fantasy-football-analyzer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsx scripts/prerender.tsx",
    "build:award-icons": "tsx scripts/sliceAwardIcons.ts",
    "build:draft-data": "tsx scripts/buildDraftPool.ts",
    "fetch:rankings": "tsx scripts/fetchRankings.ts",
    "update:rankings": "npm run fetch:rankings && npm run build:draft-data",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sentry/react": "^10.66.0",
    "fast-xml-parser": "^5.3.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/bowlby-one": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@sentry/vite-plugin": "^5.3.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vercel/node": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "gh-pages": "^6.2.0",
    "globals": "^15.11.0",
    "jsdom": "^24.0.0",
    "sharp": "^0.35.3",
    "tsx": "^4.22.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
